# Token de acesso da Meta (System User Token com permissão ads_read)
META_ACCESS_TOKEN=

# IDs das contas de anúncio separados por vírgula (ex: act_123456,act_789012)
META_ACCOUNT_IDS=

# Campanhas cujos eventos fb_pixel_custom NÃO são agendamentos (separar por vírgula)
SCHED_EXCLUDE_CAMPAIGNS=

# Campanhas para ignorar completamente da dashboard (separar por vírgula)
HIDDEN_CAMPAIGNS=
